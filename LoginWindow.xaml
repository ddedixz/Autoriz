<Window x:Class="ProductClientApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        
        Title="Авторизация" Height="250" Width="300">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Логин"/>
            <TextBox x:Name="LoginBox" Margin="0,5,0,10"/>
            
            <TextBlock Text="Пароль"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,5,0,10"/>
            
            <Button Content="Войти" Click="Login_Click"/>
        </StackPanel>
    </Grid>
</Window>
